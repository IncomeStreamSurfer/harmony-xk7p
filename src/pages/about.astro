---
import Base from '../layouts/Base.astro';
const values = [
  { title: 'Quality over speed', body: 'Every product ships only when it meets the standard. We would rather delay a launch than ship something we are not proud of.' },
  { title: 'Music first', body: 'We are fans who happen to sell things. Every product connects to real music, real artists, real history.' },
  { title: 'Simple returns', body: '30 days, no questions. If it does not fit or you do not love it, we will make it right.' },
];
---
<Base title="About — Harmony Threads" description="Harmony Threads was built for people who read liner notes." canonical="/about">
  <div style="background:var(--ink);" class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:var(--accent);">Our Story</p>
      <h1 class="text-5xl md:text-6xl font-bold leading-tight max-w-3xl" style="font-family:'Playfair Display',serif;color:var(--paper);">We built this for the people who read liner notes</h1>
    </div>
  </div>
  <section style="background:var(--paper);" class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        <div>
          <h2 class="text-3xl font-bold mb-6" style="font-family:'Playfair Display',serif;">Why we started this</h2>
          <p class="text-base leading-relaxed mb-5" style="color:var(--muted);">Rock music deserves better merch. The Band T-Shirt started as a personal project. We wore it, got asked about it constantly, and eventually had to make it available.</p>
          <p class="text-base leading-relaxed" style="color:var(--muted);">That first product led to a second idea: what if the story lived somewhere too? That is where the digital book came in.</p>
        </div>
        <div class="space-y-4">
          <div class="p-6 rounded-lg" style="background:var(--ink);color:var(--paper);"><h3 class="text-xl font-bold mb-2" style="font-family:'Playfair Display',serif;">Harmony Threads</h3><p class="text-sm" style="color:rgba(250,247,242,0.65);">Music-inspired graphic tees. Preshrunk 150g cotton.</p></div>
          <div class="p-6 rounded-lg" style="background:var(--ink);color:var(--paper);"><h3 class="text-xl font-bold mb-2" style="font-family:'Playfair Display',serif;">Harmony Publishing</h3><p class="text-sm" style="color:rgba(250,247,242,0.65);">Digital content for serious music fans. PDF, audio, and Kindle.</p></div>
        </div>
      </div>
    </div>
  </section>
  <section style="background:var(--accent);" class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-10 text-center" style="font-family:'Playfair Display',serif;color:#FAF7F2;">What we stand for</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {values.map(v => (<div class="text-center"><h3 class="text-xl font-bold mb-3" style="font-family:'Playfair Display',serif;color:#FAF7F2;">{v.title}</h3><p class="text-sm" style="color:rgba(250,247,242,0.8);">{v.body}</p></div>))}
      </div>
    </div>
  </section>
</Base>
