---
import Base from '../layouts/Base.astro';
---
<Base title="Privacy Policy — Harmony Threads" description="Privacy policy for Harmony Threads." canonical="/privacy">
  <div style="background:var(--ink);" class="pt-32 pb-12"><div class="max-w-3xl mx-auto px-6"><h1 class="text-4xl font-bold" style="font-family:'Playfair Display',serif;color:var(--paper);">Privacy Policy</h1></div></div>
  <section style="background:var(--paper);" class="py-16"><div class="max-w-3xl mx-auto px-6" style="color:var(--muted);line-height:1.8;">
    <p>Harmony Threads collects only information needed to process your order. We do not sell your data.</p>
    <h2 style="font-family:'Playfair Display',serif;color:var(--ink);font-size:1.5rem;margin-top:2rem;">What we collect</h2>
    <ul><li>Name and email for orders and enquiries</li><li>Shipping address for physical orders</li><li>Payment via Stripe only — we never see card numbers</li></ul>
    <h2 style="font-family:'Playfair Display',serif;color:var(--ink);font-size:1.5rem;margin-top:2rem;">Your rights</h2>
    <p>Request deletion by emailing <a href="mailto:hello@harmonythreads.com" style="color:var(--accent);">hello@harmonythreads.com</a>.</p>
  </div></section>
</Base>
