---
import Base from '../layouts/Base.astro';
---
<Base title="Terms of Service — Harmony Threads" description="Terms of service for Harmony Threads." canonical="/terms">
  <div style="background:var(--ink);" class="pt-32 pb-12"><div class="max-w-3xl mx-auto px-6"><h1 class="text-4xl font-bold" style="font-family:'Playfair Display',serif;color:var(--paper);">Terms of Service</h1></div></div>
  <section style="background:var(--paper);" class="py-16"><div class="max-w-3xl mx-auto px-6" style="color:var(--muted);line-height:1.8;">
    <h2 style="font-family:'Playfair Display',serif;color:var(--ink);font-size:1.5rem;">Orders</h2>
    <p>Physical items ship within 2 business days. Digital downloads delivered within 5 minutes of payment.</p>
    <h2 style="font-family:'Playfair Display',serif;color:var(--ink);font-size:1.5rem;margin-top:2rem;">Returns</h2>
    <p>Physical items returnable within 30 days. Digital downloads are non-refundable once delivered.</p>
    <h2 style="font-family:'Playfair Display',serif;color:var(--ink);font-size:1.5rem;margin-top:2rem;">Contact</h2>
    <p><a href="mailto:hello@harmonythreads.com" style="color:var(--accent);">hello@harmonythreads.com</a></p>
  </div></section>
</Base>
