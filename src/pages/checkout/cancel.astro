---
import Base from '../../layouts/Base.astro';
---
<Base title="Checkout Cancelled — Harmony Threads" description="Your cart is saved.">
  <div style="background:var(--ink);min-height:100vh;display:flex;align-items:center;justify-content:center;" class="px-6">
    <div class="max-w-lg w-full text-center py-16">
      <h1 class="text-4xl font-bold mb-4" style="font-family:'Playfair Display',serif;color:var(--paper);">No worries</h1>
      <p class="mb-8" style="color:rgba(250,247,242,0.6);">Your cart is still saved. Head back whenever you're ready.</p>
      <a href="/shop" class="px-6 py-3 text-sm font-semibold rounded" style="background:var(--accent);color:#FAF7F2;">Back to Shop</a>
    </div>
  </div>
</Base>
